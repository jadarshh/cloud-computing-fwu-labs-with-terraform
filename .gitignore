**/lambda/handler.zip

# Python
__pycache__/
*.pyc
.python_deps/
.venv/
venv/

# OS junk
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/

# Local report drafts (we keep the final committed)
report/*.tmp.docx
